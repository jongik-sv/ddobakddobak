# STT 엔진 (qwen3_asr_4bit | qwen3_asr_6bit | qwen3_asr_8bit | whisper_cpp | faster_whisper | sensevoice)
STT_ENGINE="qwen3_asr_8bit"

# AI 요약 모델 (Z.ai - Claude API 호환)
ANTHROPIC_AUTH_TOKEN="your_token_here"
ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
LLM_MODEL="claude-sonnet-4-6"

# Rails
RAILS_ENV="development"
SECRET_KEY_BASE="<run: bin/rails secret>"
# WebSocket 10명 동시 접속 대응: ActionCable 스레드당 1 연결 → 최소 10 필요
RAILS_MAX_THREADS=10

# Python Sidecar
SIDECAR_HOST="localhost"
SIDECAR_PORT="8000"

# Hugging Face (pyannote 모델 다운로드용)
HF_TOKEN="your_hf_token_here"
